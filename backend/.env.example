# Database (Prisma requires both URLs for Neon-style pooling)
# With docker-compose: host port is 5433 → use localhost:5433 below
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/atlas"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/atlas"

# Optional: legacy / unused by current Nest build (kept for future Python AI service)
REDIS_URL="redis://localhost:6379"

# JWT — must match JWT_SECRET on the Next.js frontend for verified route protection (see docs/SECURITY.md)
JWT_SECRET="your-development-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="your-development-refresh-secret-change-in-production"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="90d"

# Google Gemini (session analytics, discussion scoring, admin AI features)
# Get a key: https://aistudio.google.com/apikey — must be set on the NestJS backend (not only Vercel frontend).
GEMINI_API_KEY=""
# Primary model (keep 2.5 Flash as default for ATLAS). If it fails, fallbacks run next.
GEMINI_MODEL="gemini-2.5-flash"
# Optional comma-separated list (overrides default fallbacks — avoid retired model IDs):
# GEMINI_MODEL_FALLBACKS=gemini-1.5-flash

# Legacy AI env vars (not used by current backend; reserved for external Python services)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
AI_MODEL_PROVIDER="anthropic"
AI_MODEL_NAME="claude-3-5-haiku-20241022"
SESSION_ANALYZER_URL="http://localhost:8000"

# App
PORT=4000
NODE_ENV="development"

# Frontend URL (for CORS and email links). Local Next.js default:
FRONTEND_URL="http://localhost:3000"

# Email Configuration (Feature #16)
# For Gmail:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Generate app password at https://myaccount.google.com/apppasswords
#   3. Select "Mail" and device, copy the 16-character password
#   4. Use that password in EMAIL_PASSWORD below
EMAIL_NOTIFICATIONS_ENABLED="true"
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-specific-password-here"
EMAIL_FROM="ATLAS Platform <noreply@atlas.com>"

# Push Notifications (VAPID)
# Generate keys once with: npx web-push generate-vapid-keys
# Also set NEXT_PUBLIC_VAPID_PUBLIC_KEY in your Vercel frontend environment
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@thrivehubafrica.com"
